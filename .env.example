# ResearchPilot AI - Environment Configuration
# -----------------------------------------------
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env file to version control!

# Google Gemini API Key (get yours at https://aistudio.google.com/app/apikey)
# When set, all AI features use live Gemini 1.5 Flash generation.
# If left empty, ResearchPilot uses its built-in scientific simulator.
VITE_GEMINI_API_KEY=
